NEXT_PUBLIC_SUPABASE_URL=
# Clave pública (anon): en Vercel a veces se llama NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY; es el mismo valor.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Necesaria para npm run create-admin (usuario del panel). No subir a Git.
# No hace falta para subir imágenes en "Editar sitio": ahí se usa la sesión del admin (anon + JWT) y RLS.
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_COMPLEX_NAME=Complejo Frente al Mar

# Opcional: ajustá metadataBase en app/layout.tsx si el dominio de producción cambia.
