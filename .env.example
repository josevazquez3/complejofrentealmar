# Neon PostgreSQL (pooling + conexión directa para migraciones)
DATABASE_URL=
DIRECT_URL=

# NextAuth — en local: http://localhost:3000 ; en Vercel suele resolverse solo
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Vercel Blob (lectura/escritura). En local: npx vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_COMPLEX_NAME=Complejo Frente al Mar
