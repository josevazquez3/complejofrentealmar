# Neon PostgreSQL — pegá la connection string del dashboard (Pooled suele ir bien con Prisma).
# Copiá a .env.local (Next.js). Para npx prisma sin script: duplicá también en .env en la raíz.
# Si la contraseña tiene #, usá comillas: DATABASE_URL="postgresql://..."
DATABASE_URL=
# Opcional (Neon «Connection string» → Direct / sin pooler). Evita timeouts en migrate deploy (advisory lock).
# También acepta DIRECT_URL o POSTGRES_URL_NON_POOLING (Vercel).
# DATABASE_URL_UNPOOLED=
#
# Si migrate sigue fallando con P1002 (timeout en pg_advisory_lock), usá: npm run db:migrate:no-lock
# (equivale a PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK — no correr dos migraciones a la vez).

# NextAuth / Auth.js — en local: http://localhost:3000 ; en Vercel suele resolverse solo
NEXTAUTH_URL=http://localhost:3000
# Generar: openssl rand -base64 32  (Auth.js v5 también acepta AUTH_SECRET)
NEXTAUTH_SECRET=
# AUTH_SECRET=

# Vercel Blob (lectura/escritura). En local: npx vercel env pull .env.local
# Si está vacío y NODE_ENV=development, las imágenes se guardan en public/uploads/ (sin Vercel).
BLOB_READ_WRITE_TOKEN=

NEXT_PUBLIC_COMPLEX_NAME=Complejo Frente al Mar

# GIF promocional en la portada: copiá el .gif a public/ (ej. public/promo.gif) y definí la ruta pública:
# NEXT_PUBLIC_PROMO_GIF_URL=/promo.gif
# O URL absoluta (p. ej. archivo subido a Vercel Blob).
