# Neon PostgreSQL — pegá la connection string del dashboard (Pooled suele ir bien con Prisma).
# Copiá a .env.local (Next.js). Para npx prisma sin script: duplicá también en .env en la raíz.
# Si la contraseña tiene #, usá comillas: DATABASE_URL="postgresql://..."
DATABASE_URL=

# NextAuth — en local: http://localhost:3000 ; en Vercel suele resolverse solo
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Vercel Blob (lectura/escritura). En local: npx vercel env pull .env.local
# Si está vacío y NODE_ENV=development, las imágenes se guardan en public/uploads/ (sin Vercel).
BLOB_READ_WRITE_TOKEN=

NEXT_PUBLIC_COMPLEX_NAME=Complejo Frente al Mar
