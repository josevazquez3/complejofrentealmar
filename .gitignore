# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generado por npm run setup-complejo-schema (bundle para SQL Editor)

# Subidas locales cuando no hay BLOB_READ_WRITE_TOKEN (solo desarrollo)
/public/uploads/*
!/public/uploads/.gitkeep

# Python (gif_maker u otros scripts)
__pycache__/
*.py[cod]